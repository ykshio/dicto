#!/bin/bash
# dicto ランチャー
# pythonをバックグラウンドで起動し、サーバー待機は別プロセスに任せてすぐ終了する

INSTALL_DIR="$(cat "$(dirname "$0")/../Resources/install_path.txt" 2>/dev/null)"

if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
    osascript -e 'display dialog "アプリのインストール先が見つかりません。\nインストールコマンドを再実行してください。" buttons {"OK"} default button "OK" with icon stop with title "dicto"'
    exit 1
fi

if [ ! -d "$INSTALL_DIR/venv" ]; then
    osascript -e 'display dialog "Python環境が見つかりません。\nインストールコマンドを再実行してください。" buttons {"OK"} default button "OK" with icon stop with title "dicto"'
    exit 1
fi

# 既に起動中なら、ブラウザだけ開いて終了
if lsof -ti:7860 >/dev/null 2>&1; then
    open "http://127.0.0.1:7860"
    exit 0
fi

# pythonをバックグラウンドで起動
cd "$INSTALL_DIR"
nohup caffeinate -is ./venv/bin/python app.py >/dev/null 2>&1 &

# サーバー待機→ブラウザを開くのも別プロセスで(ランチャー自体はすぐ終了)
(
    for i in $(seq 1 120); do
        if curl -s http://127.0.0.1:7860 >/dev/null 2>&1; then
            open "http://127.0.0.1:7860"
            exit 0
        fi
        sleep 1
    done
    osascript -e 'display dialog "アプリの起動に失敗しました。\nもう一度お試しください。" buttons {"OK"} default button "OK" with icon stop with title "dicto"'
) &

exit 0
